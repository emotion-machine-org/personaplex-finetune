# Copy to .env and fill in your own values. Never commit .env.

# Anthropic API key — used by:
#   - pipeline/generate_dialogues_sync.py (synthetic dialogue generation)
#   - pipeline/batch_eval.py (LLM transcript review)
#   - moshi-finetune/finetune/gen_eval.py (LLM transcript review at checkpoint)
ANTHROPIC_API_KEY=

# Gemini API key — optional, used by pipeline/gemini_eval.py for an
# alternative LLM reviewer.
GEMINI_API_KEY=

# HuggingFace token — only needed if you gate-pull a private model.
HF_TOKEN=

# WandB API key — for training metrics. You can also set this via
# `wandb login` once and skip this var.
WANDB_API_KEY=

# NCCL transport — set to Socket on single-GPU GCP instances (no
# InfiniBand). Leave unset on HPC clusters with proper IB fabric.
NCCL_NET=Socket
